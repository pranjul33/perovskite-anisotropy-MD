#Initialization----------
units       real
boundary p p p
atom_style  full
pair_style   hybrid lj/charmm/coul/long 9.9 10. buck/coul/long 9.9 10.
bond_style      harmonic
angle_style     harmonic
special_bonds   amber
dihedral_style  charmm
kspace_style pppm 1.0e-4
kspace_modify diff ad

#Reading data file(with bonded interactions) and potential file(non bonded)------------
read_data    mp1194604(777).data
include dlpoly2lammps.nonbonding

#group lead type 1
#group iodine type 2
#group methylammonium molecule <> 5489 6860


#Minimization----------------
timestep 1
fix 1 all box/relax iso 0.0 vmax 0.001
thermo 1
thermo_style custom step time cella cellb cellc pe ke etotal press vol temp density
#dump dump1 all custom 1000 dump777.dump id element type x y z vx vy vz fx fy fz
#dump_modify dump1 element Pb I H N C H
minimize 1.0e-6 1.0e-6 50000 1000000
print "Finished Minimizing!"
unfix 1
#undump dump1

reset_timestep 0

# Molecular Dynamics Run-----------------
timestep 1
velocity all create 300 111888 dist gaussian mom yes rot yes
fix 1 all nve
thermo 10
thermo_style custom step time cella cellb cellc pe ke etotal press vol temp
#dump dump1 all custom 1000 NVE.dump id element type x y z vx vy vz fx fy fz
#dump_modify dump1 element Pb I H N C H
run 10000
unfix 1
#undump dump1


#Changing T using NVT----------------
fix 1 all nvt temp 300 300 100 
thermo 200
thermo_style custom step time cella cellb cellc pe ke etotal press vol temp
#dump dump1 all custom 20000 NVT.dump id element type x y z vx vy vz fx fy fz
#dump_modify dump1 element Pb I H N C H
run 200000
unfix 1
#undump dump1

reset_timestep 0

#Changing P and T using NPT----------------
fix 1 all npt temp 300 300 100 aniso 1 1 1000 
thermo 1000
thermo_style custom step time cella cellb cellc pe ke etotal enthalpy vol press temp
dump dump1 all custom 1000 NPT.* id element x y z 
dump_modify dump1 element Pb I H N C H
run 1000000
unfix 1
undump dump1

write_data NPT777_aniso.data
write_restart restart777_aniso.txt

#Check the equilibriation using NVE ensemble--------------
fix 1 all nve
thermo 10
thermo_style custom step time cella cellb cellc pe ke etotal press vol temp
run 10000
unfix 1



print "All done"